{
  "name": "charity-system",
  "version": "2.0.0",
  "description": "نظام إدارة البحث الاجتماعي - النسخة المتكاملة مع الذكاء الاصطناعي والبوتات",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron": "electron .",
    "build-win": "electron-builder --win",
    "build-linux": "electron-builder --linux",
    "build-all": "electron-builder --win --linux",
    "postinstall": "npm run setup-dirs",
    "setup-dirs": "node -e \"const fs=require('fs');['data','data/cases','data/attachments','data/backups','data/temp','logs','uploads'].forEach(d=>fs.mkdirSync(d,{recursive:true}))\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "sqlite3": "^5.1.6",
    "multer": "^1.4.5-lts.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.charity.system",
    "productName": "نظام إدارة البحث الاجتماعي",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "public/assets/logo.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "public/assets/logo.png",
      "category": "Office"
    },
    "files": [
      "electron/**/*",
      "core/**/*",
      "ui/**/*",
      "modules/**/*",
      "public/**/*",
      "utils/**/*",
      "data/**/*",
      "admin/**/*",
      "user/**/*",
      "server.js",
      "package.json"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "keywords": [
    "charity",
    "social-research",
    "case-management",
    "ai",
    "telegram-bot"
  ],
  "author": "سيد راشد",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
